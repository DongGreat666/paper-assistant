# === AI Model Configuration ===
# Get your API key from: https://platform.openai.com/api-keys
LLM_API_KEY=sk-your-api-key-here
# API base URL - change this for different providers:
#   OpenAI:     https://api.openai.com/v1
#   NVIDIA NIM: https://integrate.api.nvidia.com/v1
#   Ollama:     http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# --- NVIDIA NIM (optional, for NVIDIA models) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Default model (fallback for all tasks) ---
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# --- DeepSeek (optional) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Task-specific models (leave empty to use default) ---
# Translation: small model is enough, fast and cheap
# Optional: use a separate OpenAI-compatible endpoint/key for translation.
# Leave empty to reuse LLM_API_KEY and LLM_BASE_URL.
TRANSLATE_API_KEY=
TRANSLATE_BASE_URL=
TRANSLATE_MODEL=
TRANSLATE_TEMPERATURE=0.2

# RAG Q&A: needs strong reasoning over long documents
QA_MODEL=gpt-4o
QA_TEMPERATURE=0.3

# Summarization: balanced quality and cost
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.3

# === RAG / Embedding ===
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# === Storage Paths ===
PAPERS_DIR=./papers
DATA_DIR=./data

# === Application ===
APP_TITLE=Paper Assistant
DEBUG=False

# === ML Model Cache ===
MODEL_CACHE_DIR=./models
